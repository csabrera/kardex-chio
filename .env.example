# KardexChio - Configuración de Entorno (Docker Compose)
# Copiar a .env y ajustar valores según tu entorno

# ========== BASE DE DATOS ==========
# PostgreSQL - Usar cuando se levanta con Docker Compose
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=kardexchio
POSTGRES_PASSWORD=kardexchio_2026
POSTGRES_DB=kardexchio

# ========== BACKEND ==========
# Puerto donde corre el backend (Docker)
BACKEND_PORT=3001

# Clave secreta para JWT - CAMBIAR EN PRODUCCIÓN
JWT_SECRET=tu_clave_secreta_jwt_muy_segura_aqui_minimo_32_caracteres

# ========== FRONTEND ==========
# URL base para las llamadas API desde el frontend (Docker)
NEXT_PUBLIC_API_URL=http://localhost:3011/api
