# KardexChio Backend - Configuración Local
# Copiar a .env y ajustar valores según tu entorno

# ========== BASE DE DATOS (Desarrollo Local) ==========
# Cuando ejecutas PostgreSQL localmente en otro puerto
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_USER=kardexchio
POSTGRES_PASSWORD=kardexchio_2026
POSTGRES_DB=kardexchio

# ========== AUTENTICACIÓN ==========
# Clave secreta para firmar JWT tokens
# Mínimo 32 caracteres, cambiar en producción
JWT_SECRET=tu_clave_secreta_jwt_muy_segura_aqui_minimo_32_caracteres

# ========== ENTORNO ==========
# NODE_ENV=development (por defecto para npm run start:dev)
# NODE_ENV=production (para builds de producción)
